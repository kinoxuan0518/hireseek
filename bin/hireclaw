#!/usr/bin/env node
const path = require('path');
const { spawn } = require('child_process');

// 获取项目根目录
const projectRoot = path.join(__dirname, '..');
const indexPath = path.join(projectRoot, 'dist', 'index.js');

// 运行编译后的 JS 文件
const child = spawn('node', [indexPath, ...process.argv.slice(2)], {
  cwd: projectRoot,
  stdio: 'inherit'
});

child.on('exit', (code) => {
  process.exit(code || 0);
});
