# ── HireSeek 配置示例（复制为 .env 并填写）──────────────────────────

# ── LLM Provider ──────────────────────────────────────────
# 可选: deepseek（默认）| claude | openai | minimax | custom
# LLM_PROVIDER=deepseek

# DeepSeek（默认大脑，唯一必填）
DEEPSEEK_API_KEY=sk-your-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 注意：deepseek-chat/deepseek-reasoner 旧模型名 2026-07-24 弃用，请用 v4 系列
# LLM_MODEL=deepseek-v4-flash
# DEEPSEEK_REASONER_MODEL=deepseek-v4-pro

# ── 其他 provider（只填你用的）──────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# 其他 OpenAI 兼容 provider（Qwen、GLM、Moonshot 等）
# LLM_PROVIDER=custom
# CUSTOM_API_KEY=your_key
# CUSTOM_BASE_URL=https://your-provider/v1
# LLM_MODEL=your-model-name

# ── 数据库 ─────────────────────────────────────────────────
# 默认 ~/.hireseek/hireseek.db（自动兼容旧 ~/.hireclaw/hireclaw.db）
# HIRESEEK_DB_PATH=

# ── 飞书：执行报告推送（可选）──────────────────────────────
# 飞书群自定义机器人 Webhook，不填则结果只打印到终端
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ── 飞书：多维表格读取（进化闭环，可选）────────────────────
# 自建应用需开通 bitable:app:readonly 权限
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BITABLE_APP_TOKEN=
# FEISHU_BITABLE_TABLE_ID=

# ── 浏览器 ─────────────────────────────────────────────────
# 招聘平台有反爬，默认不用 headless 模式
BROWSER_HEADLESS=false

# ── 定时任务（Cron，工作日自动触发）──────────────────────
SCHEDULE_BOSS=0 9 * * 1-5
SCHEDULE_MAIMAI=0 10 * * 1-5
SCHEDULE_FOLLOWUP=0 14 * * 1-5
