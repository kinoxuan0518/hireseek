# ── LLM Provider ──────────────────────────────────────────
# 可选: claude（默认）| openai | minimax | custom
LLM_PROVIDER=claude

# 覆盖默认模型（可选，留空用 provider 默认值）
# claude  默认: claude-opus-4-6
# openai  默认: computer-use-preview
# minimax 默认: MiniMax-Text-01
# LLM_MODEL=

# ── API Keys（只填你用的 provider）──────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# 其他 OpenAI 兼容 provider（Qwen、GLM、Moonshot 等）
# LLM_PROVIDER=custom
# CUSTOM_API_KEY=your_key
# CUSTOM_BASE_URL=https://your-provider/v1
# LLM_MODEL=your-model-name

# ── 数据库 ─────────────────────────────────────────────────
# 默认存在 ~/.hireclaw/hireclaw.db，无需修改
# HIRECLAW_DB_PATH=~/.hireclaw/hireclaw.db

# ── 飞书通知（可选）────────────────────────────────────────
# 飞书群自定义机器人 Webhook，用于接收每日 sourcing 报告
# 不填则结果只打印到终端
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ── 浏览器 ─────────────────────────────────────────────────
# 招聘平台有反爬，默认不用 headless 模式
BROWSER_HEADLESS=false

# ── 定时任务（Cron，工作日自动触发）──────────────────────
SCHEDULE_BOSS=0 9 * * 1-5
SCHEDULE_MAIMAI=0 10 * * 1-5
SCHEDULE_FOLLOWUP=0 14 * * 1-5
