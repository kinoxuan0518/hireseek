    "agent": "tsx src/index.ts",
    "chat": "tsx src/index.ts chat"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^4.1.2",
    "dayjs": "^1.11.0",
    "dotenv": "^16.4.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "node-cron": "^3.0.0",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
